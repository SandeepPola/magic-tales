# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Get your OpenAI API key from https://platform.openai.com/api-keys
# This is needed for professional text-to-speech audio
OPENAI_API_KEY=your_openai_api_key_here

# Authentication - set a strong password for your app
APP_PASSWORD=storymagic123

# JWT secret for token signing (change this to a random string in production)
JWT_SECRET=your-random-secret-key-here

# Optional: port to run server on (default: 3001)
# PORT=3001
